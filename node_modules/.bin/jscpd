#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/luka/work/astral-desktop/node_modules/.pnpm/jscpd@4.0.8/node_modules/jscpd/bin/node_modules:/Users/luka/work/astral-desktop/node_modules/.pnpm/jscpd@4.0.8/node_modules/jscpd/node_modules:/Users/luka/work/astral-desktop/node_modules/.pnpm/jscpd@4.0.8/node_modules:/Users/luka/work/astral-desktop/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/luka/work/astral-desktop/node_modules/.pnpm/jscpd@4.0.8/node_modules/jscpd/bin/node_modules:/Users/luka/work/astral-desktop/node_modules/.pnpm/jscpd@4.0.8/node_modules/jscpd/node_modules:/Users/luka/work/astral-desktop/node_modules/.pnpm/jscpd@4.0.8/node_modules:/Users/luka/work/astral-desktop/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../jscpd/bin/jscpd" "$@"
else
  exec node  "$basedir/../jscpd/bin/jscpd" "$@"
fi
